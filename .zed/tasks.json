[
  {
    "label": "CMake Configure (Debug)",
    "command": "cmake -B build/debug -G Ninja -DCMAKE_BUILD_TYPE=Debug -DCMAKE_C_COMPILER=clang -DCMAKE_CXX_COMPILER=clang++ -DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
    "cwd": "${ZED_WORKTREE_ROOT}",
    "reveal": "always",
    "hide": "on_success",
  },
  {
    "label": "CMake Configure (Release)",
    "command": "cmake -B build/release -G Ninja -DCMAKE_BUILD_TYPE=Release -DCMAKE_C_COMPILER=clang -DCMAKE_CXX_COMPILER=clang++ -DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
    "cwd": "${ZED_WORKTREE_ROOT}",
    "reveal": "always",
    "hide": "on_success",
  },
  {
    "label": "Build (Debug)",
    "command": "cmake -B build/debug -G Ninja -DCMAKE_BUILD_TYPE=Debug -DCMAKE_C_COMPILER=clang -DCMAKE_CXX_COMPILER=clang++ -DCMAKE_EXPORT_COMPILE_COMMANDS=ON && cmake --build build/debug",
    "cwd": "${ZED_WORKTREE_ROOT}",
    "reveal": "always",
    "hide": "never",
  },
  {
    "label": "Build (Release)",
    "command": "cmake -B build/release -G Ninja -DCMAKE_BUILD_TYPE=Release -DCMAKE_C_COMPILER=clang -DCMAKE_CXX_COMPILER=clang++ -DCMAKE_EXPORT_COMPILE_COMMANDS=ON && cmake --build build/release",
    "cwd": "${ZED_WORKTREE_ROOT}",
    "reveal": "always",
    "hide": "never",
  },
  {
    "label": "Run (Debug)",
    "command": "./build/debug/template_project",
    "cwd": "${ZED_WORKTREE_ROOT}",
    "reveal": "always",
    "use_new_terminal": false,
  },
  {
    "label": "Run (Release)",
    "command": "./build/release/template_project",
    "cwd": "${ZED_WORKTREE_ROOT}",
    "reveal": "always",
    "use_new_terminal": false,
  },
  {
    "label": "Build & Run (Debug)",
    "command": "cmake -B build/debug -G Ninja -DCMAKE_BUILD_TYPE=Debug -DCMAKE_C_COMPILER=clang -DCMAKE_CXX_COMPILER=clang++ -DCMAKE_EXPORT_COMPILE_COMMANDS=ON && cmake --build build/debug && ./build/debug/template_project",
    "cwd": "${ZED_WORKTREE_ROOT}",
    "reveal": "always",
  },
  {
    "label": "Build & Run (Release)",
    "command": "cmake -B build/release -G Ninja -DCMAKE_BUILD_TYPE=Release -DCMAKE_C_COMPILER=clang -DCMAKE_CXX_COMPILER=clang++ -DCMAKE_EXPORT_COMPILE_COMMANDS=ON && cmake --build build/release && ./build/release/template_project",
    "cwd": "${ZED_WORKTREE_ROOT}",
    "reveal": "always",
  },
  {
    "label": "Clean (Debug)",
    "command": "cmake --build build/debug --target clean",
    "cwd": "${ZED_WORKTREE_ROOT}",
    "reveal": "always",
    "hide": "on_success",
  },
  {
    "label": "Clean (Release)",
    "command": "cmake --build build/release --target clean",
    "cwd": "${ZED_WORKTREE_ROOT}",
    "reveal": "always",
    "hide": "on_success",
  },
  {
    "label": "Clean & Rebuild (Debug)",
    "command": "cmake --build build/debug --target clean && cmake --build build/debug",
    "cwd": "${ZED_WORKTREE_ROOT}",
    "reveal": "always",
  },
  {
    "label": "Clean & Rebuild (Release)",
    "command": "cmake --build build/release --target clean && cmake --build build/release",
    "cwd": "${ZED_WORKTREE_ROOT}",
    "reveal": "always",
  },
  {
    "label": "Delete Build (Debug)",
    "command": "rm -rf build/debug",
    "cwd": "${ZED_WORKTREE_ROOT}",
    "reveal": "always",
    "hide": "on_success",
  },
  {
    "label": "Delete Build (Release)",
    "command": "rm -rf build/release",
    "cwd": "${ZED_WORKTREE_ROOT}",
    "reveal": "always",
    "hide": "on_success",
  },
  {
    "label": "Delete All Builds",
    "command": "rm -rf build",
    "cwd": "${ZED_WORKTREE_ROOT}",
    "reveal": "always",
    "hide": "on_success",
  },
  {
    "label": "Format Current File",
    "command": "clang-format -i \"${ZED_FILE}\"",
    "cwd": "${ZED_WORKTREE_ROOT}",
    "reveal": "never",
    "hide": "always",
  },
  {
    "label": "Format All Source Files",
    "command": "find src include -name '*.cpp' -o -name '*.hpp' | xargs clang-format -i",
    "cwd": "${ZED_WORKTREE_ROOT}",
    "reveal": "always",
    "hide": "on_success",
  },
  {
    "label": "Clang-Tidy Current File",
    "command": "clang-tidy -p build/debug \"${ZED_FILE}\"",
    "cwd": "${ZED_WORKTREE_ROOT}",
    "reveal": "always",
  },
  {
    "label": "Clang-Tidy All Files",
    "command": "find src -name '*.cpp' | xargs clang-tidy -p build/debug",
    "cwd": "${ZED_WORKTREE_ROOT}",
    "reveal": "always",
  },
  {
    "label": "Generate .cpp Stubs from Header",
    "command": "python3 .zed/generate_cpp_stubs.py \"${ZED_RELATIVE_FILE}\"",
    "cwd": "${ZED_WORKTREE_ROOT}",
    "reveal": "always",
  },
]
