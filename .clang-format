Language: Cpp
BasedOnStyle: LLVM

# Rust uses K&R style: opening braces attached, else/catch on same line as closing brace
BreakBeforeBraces: Attach
ColumnLimit: 120
PointerAlignment: Left
ReferenceAlignment: Left
SortIncludes: Never

# Indentation (Rust uses 4 spaces)
IndentWidth: 4
TabWidth: 4
UseTab: Never
AccessModifierOffset: -4

# Spacing
SpaceAfterCStyleCast: false
SpaceBeforeParens: ControlStatements
SpaceInEmptyParentheses: false
SpacesBeforeTrailingComments: 1

# Alignment — Rust does not align consecutive assignments or declarations
AlignConsecutiveAssignments: false
AlignConsecutiveDeclarations: false
AlignOperands: false

# Argument packing — Rust breaks to one-per-line when args don't fit on one line
BinPackParameters: false
BinPackArguments: false

# Rust never collapses functions or loops to a single line
AllowShortFunctionsOnASingleLine: Empty
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false

# C++ specific
Cpp11BracedListStyle: true
SpaceBeforeCpp11BracedList: true
CompactNamespaces: false
