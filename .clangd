CompileFlags:
  # Use compile_commands.json from build dir
  CompilationDatabase: build/debug

Diagnostics:
  # Enable clang-tidy checks
  ClangTidy:
    Add: []
    CheckOptions:
      # Inherit all settings from .clang-tidy file
      InheritParentConfig: true

  # Show diagnostics from all included headers
  UnusedIncludes: Strict

  # Suppress noisy diagnostics from generated/vendored headers
  Suppress:
    - "pp_file_not_found"

Completion:
  AllScopes: Yes

InlayHints:
  # Show type hints for auto variables
  DeducedTypes: Yes
  # Show parameter names in function calls
  ParameterNames: Yes

Hover:
  # Show more detailed information on hover
  ShowAKA: Yes
